{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magazine-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-magazine-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-magazine-featured-{{ ai_gen_id }} {
    grid-column: span 8;
    position: relative;
    overflow: hidden;
  }

  .ai-magazine-featured-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 500px;
    object-fit: cover;
    display: block;
  }

  .ai-magazine-featured-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 500px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-magazine-featured-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-featured-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.content_padding }}px;
    background: linear-gradient(to top, {{ block.settings.overlay_color }}, transparent);
    color: {{ block.settings.featured_text_color }};
  }

  .ai-magazine-featured-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_size }}px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
    font-weight: 600;
    color: {{ block.settings.featured_text_color }};
  }

  .ai-magazine-featured-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.featured_title_size }}px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 12px;
    color: {{ block.settings.featured_text_color }};
  }

  .ai-magazine-featured-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    line-height: 1.6;
    margin-bottom: 16px;
    color: {{ block.settings.featured_text_color }};
    opacity: 0.9;
  }

  .ai-magazine-featured-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 10px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    border-radius: 4px;
    transition: background-color 0.3s ease;
  }

  .ai-magazine-featured-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-magazine-sidebar-{{ ai_gen_id }} {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background-color: {{ block.settings.card_background }};
  }

  .ai-magazine-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
  }

  .ai-magazine-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 240px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-magazine-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-magazine-card-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_category_size }}px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
    font-weight: 600;
    color: {{ block.settings.category_color }};
  }

  .ai-magazine-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 8px;
    color: {{ block.settings.text_color }};
  }

  .ai-magazine-card-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_excerpt_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
  }

  .ai-magazine-card-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .ai-magazine-card-link-{{ ai_gen_id }}:hover .ai-magazine-card-title-{{ ai_gen_id }} {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-magazine-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 989px) {
    .ai-magazine-featured-{{ ai_gen_id }} {
      grid-column: span 12;
    }

    .ai-magazine-sidebar-{{ ai_gen_id }} {
      grid-column: span 12;
      flex-direction: row;
      flex-wrap: wrap;
    }

    .ai-magazine-card-{{ ai_gen_id }} {
      flex: 1 1 calc(50% - {{ block.settings.grid_gap | divided_by: 2 }}px);
      min-width: 280px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-magazine-layout-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px;
    }

    .ai-magazine-featured-image-{{ ai_gen_id }},
    .ai-magazine-featured-placeholder-{{ ai_gen_id }} {
      min-height: 350px;
    }

    .ai-magazine-featured-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.featured_title_size | times: 0.7 }}px;
    }

    .ai-magazine-card-{{ ai_gen_id }} {
      flex: 1 1 100%;
    }

    .ai-magazine-sidebar-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }
{% endstyle %}

<div class="ai-magazine-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-magazine-grid-{{ ai_gen_id }}">
    <div class="ai-magazine-featured-{{ ai_gen_id }}">
      {% if block.settings.featured_image %}
        <img
          src="{{ block.settings.featured_image | image_url: width: 1200 }}"
          alt="{{ block.settings.featured_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.featured_image.width }}"
          height="{{ block.settings.featured_image.height }}"
          class="ai-magazine-featured-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-magazine-featured-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-magazine-empty-state-{{ ai_gen_id }}">
            Add a featured image
          </div>
        </div>
      {% endif %}

      <div class="ai-magazine-featured-content-{{ ai_gen_id }}">
        {% if block.settings.featured_category != blank %}
          <div class="ai-magazine-featured-category-{{ ai_gen_id }}">
            {{ block.settings.featured_category }}
          </div>
        {% endif %}

        {% if block.settings.featured_title != blank %}
          <h2 class="ai-magazine-featured-title-{{ ai_gen_id }}">
            {{ block.settings.featured_title }}
          </h2>
        {% endif %}

        {% if block.settings.featured_excerpt != blank %}
          <div class="ai-magazine-featured-excerpt-{{ ai_gen_id }}">
            {{ block.settings.featured_excerpt }}
          </div>
        {% endif %}

        {% if block.settings.featured_link != blank %}
          <a
            href="{{ block.settings.featured_link }}"
            class="ai-magazine-featured-link-{{ ai_gen_id }}"
          >
            {{ block.settings.featured_button_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="ai-magazine-sidebar-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_category_key = 'card_' | append: i | append: '_category'
          assign card_title_key = 'card_' | append: i | append: '_title'
          assign card_excerpt_key = 'card_' | append: i | append: '_excerpt'
          assign card_link_key = 'card_' | append: i | append: '_link'

          assign card_image = block.settings[card_image_key]
          assign card_category = block.settings[card_category_key]
          assign card_title = block.settings[card_title_key]
          assign card_excerpt = block.settings[card_excerpt_key]
          assign card_link = block.settings[card_link_key]
        %}

        <div class="ai-magazine-card-{{ ai_gen_id }}">
          {% if card_link != blank %}
            <a href="{{ card_link }}" class="ai-magazine-card-link-{{ ai_gen_id }}">
          {% endif %}

          {% if card_image %}
            <img
              src="{{ card_image | image_url: width: 600 }}"
              alt="{{ card_image.alt | escape }}"
              loading="lazy"
              width="{{ card_image.width }}"
              height="{{ card_image.height }}"
              class="ai-magazine-card-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-magazine-card-placeholder-{{ ai_gen_id }}">
              {{ 'product-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          <div class="ai-magazine-card-content-{{ ai_gen_id }}">
            {% if card_category != blank %}
              <div class="ai-magazine-card-category-{{ ai_gen_id }}">
                {{ card_category }}
              </div>
            {% endif %}

            {% if card_title != blank %}
              <h3 class="ai-magazine-card-title-{{ ai_gen_id }}">
                {{ card_title }}
              </h3>
            {% endif %}

            {% if card_excerpt != blank %}
              <div class="ai-magazine-card-excerpt-{{ ai_gen_id }}">
                {{ card_excerpt }}
              </div>
            {% endif %}
          </div>

          {% if card_link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

