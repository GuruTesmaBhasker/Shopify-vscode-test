{{ 'react-customizer.css' | asset_url | stylesheet_tag }}

<div class="react-customizer-section page-width" style="margin: 40px auto;">
  <!-- Added dynamic heading for the section -->
  {% if section.settings.title != blank %}
    <h2 style="text-align: center; margin-bottom: 20px;">{{ section.settings.title }}</h2>
  {% endif %}

  <!-- React will inject the app into this wrapper -->
  <div 
    id="react-customizer-root" 
    data-variant-id="{{ section.settings.base_product.selected_or_first_available_variant.id | default: 123456789 }}"
    data-product-handle="{{ section.settings.base_product.handle }}"
    data-mockup-url="{{ section.settings.mockup_image | img_url: '600x600' }}"
  ></div>
</div>

<script src="{{ 'react-customizer.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Case Configurator",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Design Your Custom Phone Case"
    },
    {
      "type": "product",
      "id": "base_product",
      "label": "Base Configurator Product",
      "info": "Select the standard Shopify product for the 'Glass vs Plastic' pricing in checkout."
    },
    {
      "type": "image_picker",
      "id": "mockup_image",
      "label": "Phone Mockup Image (Transparent PNG)",
      "info": "Upload a blank phone case with a transparent window where the user's design will show."
    }
  ],
  "presets": [
    {
      "name": "Case Configurator",
      "category": "Custom"
    }
  ]
}
{% endschema %}
