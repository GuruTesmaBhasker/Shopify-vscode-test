<!-- Load Tailwind CSS & FontAwesome specifically for this section -->
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    /* Custom scrollbar for a cleaner look */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #f1f1f1; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    
    /* Pattern background for the customizer area */
    .bg-pattern {
        background-color: #f8fafc;
        background-image: radial-gradient(#cbd5e1 1px, transparent 1px);
        background-size: 20px 20px;
    }

    .phone-container {
        width: 240px;
        height: 480px;
        border-radius: 36px;
        position: relative;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        overflow: hidden;
        background: #ffffff;
        transition: all 0.3s ease;
    }

    .phone-container.glass-case {
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 0 15px rgba(255, 255, 255, 0.8) inset, 0 0 20px rgba(0,0,0,0.2);
    }

    .phone-container.plastic-case {
        border: 2px solid #e2e8f0;
    }

    #design-image {
        position: absolute;
        transform-origin: center;
        cursor: grab;
        user-select: none;
        -webkit-user-drag: none;
        min-width: 100%;
        min-height: 100%;
        object-fit: cover;
    }

    #design-image:active {
        cursor: grabbing;
    }

    /* SVG overlay for phone details (camera, borders, glare) */
    .phone-overlay {
        position: absolute;
        inset: 0;
        pointer-events: none; /* Let clicks pass through to the image */
        z-index: 10;
    }
    
    .loader {
        border-top-color: #3498db;
        -webkit-animation: spinner 1.5s linear infinite;
        animation: spinner 1.5s linear infinite;
    }
    @keyframes spinner {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
</style>

<div class="vanilla-customizer-wrapper bg-gray-50 text-gray-800 font-sans py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Added dynamic section title -->
      {% if section.settings.title != blank %}
        <div class="flex items-center gap-2 mb-8">
            <i class="fa-solid fa-mobile-screen-button text-indigo-600 text-3xl"></i>
            <span class="font-bold text-3xl tracking-tight">{{ section.settings.title }}</span>
        </div>
      {% endif %}

      <div class="flex flex-col lg:flex-row gap-8">
          
          <!-- Left Column: Live Preview (Canvas) -->
          <div class="w-full lg:w-1/2 flex flex-col items-center justify-center bg-white rounded-2xl shadow-sm border border-gray-100 p-8 min-h-[600px] bg-pattern relative">
              
              <h2 class="absolute top-6 left-6 text-lg font-semibold text-gray-700">Live Preview</h2>
              
              <!-- Phone Mockup Container -->
              <div id="phone-mockup" class="phone-container plastic-case mt-8">
                  <!-- Uploaded Image -->
                  <img id="design-image" src="" alt="Your Design" style="display: none; transform: translate(0px, 0px) scale(1);" crossorigin="anonymous" />
                  
                  <!-- Placeholder Text -->
                  <div id="placeholder-text" class="absolute inset-0 flex flex-col items-center justify-center text-gray-400 p-6 text-center pointer-events-none">
                      <i class="fa-solid fa-cloud-arrow-up text-4xl mb-3"></i>
                      <p class="text-sm font-medium">Upload an image to start customizing</p>
                  </div>

                  <!-- SVG Overlay (Camera Hole & Lighting) -->
                  <svg class="phone-overlay" viewBox="0 0 240 480" xmlns="http://www.w3.org/2000/svg">
                      <!-- Outer Border matching radius -->
                      <rect x="0" y="0" width="240" height="480" rx="36" fill="none" stroke="#1f2937" stroke-width="6" opacity="0.1" />
                      <rect x="1" y="1" width="238" height="478" rx="35" fill="none" stroke="#ffffff" stroke-width="2" opacity="0.5" />
                      
                      <!-- Dynamic Camera Module (Changes based on selection) -->
                      <g id="camera-module">
                          <!-- Default Apple Style -->
                          <rect x="16" y="20" width="55" height="60" rx="12" fill="#1f2937" />
                          <circle cx="30" cy="35" r="8" fill="#0f172a" stroke="#334155" stroke-width="2"/>
                          <circle cx="30" cy="65" r="8" fill="#0f172a" stroke="#334155" stroke-width="2"/>
                          <circle cx="55" cy="50" r="5" fill="#0f172a" />
                      </g>

                      <!-- Glass Glare Effect (Hidden by default) -->
                      <path id="glass-glare" d="M -50 -50 L 150 480 L 200 480 L 0 -50 Z" fill="url(#glare-gradient)" opacity="0" />
                      
                      <defs>
                          <linearGradient id="glare-gradient" x1="0" y1="0" x2="1" y2="1">
                              <stop offset="0%" stop-color="white" stop-opacity="0.4" />
                              <stop offset="50%" stop-color="white" stop-opacity="0.0" />
                              <stop offset="100%" stop-color="white" stop-opacity="0.0" />
                          </linearGradient>
                      </defs>
                  </svg>
              </div>

              <div class="mt-6 flex items-center gap-2 text-sm text-gray-500">
                  <i class="fa-solid fa-hand-pointer"></i> Drag to reposition. Use slider below to zoom.
              </div>
          </div>

          <!-- Right Column: Controls -->
          <div class="w-full lg:w-1/2 flex flex-col gap-6">
              
              <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                  <h3 class="text-xl font-bold mb-4 text-gray-800">1. Select Your Device</h3>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                      <div>
                          <label class="block text-sm font-medium text-gray-700 mb-1">Brand</label>
                          <select id="brand-select" class="w-full rounded-lg border-gray-300 border p-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all text-gray-800">
                              <!-- Populated by JS -->
                          </select>
                      </div>
                      <div>
                          <label class="block text-sm font-medium text-gray-700 mb-1">Model</label>
                          <select id="model-select" class="w-full rounded-lg border-gray-300 border p-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all text-gray-800">
                              <!-- Populated by JS -->
                          </select>
                      </div>
                  </div>
              </div>

              <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                  <h3 class="text-xl font-bold mb-4 text-gray-800">2. Choose Case Type</h3>
                  <div class="grid grid-cols-2 gap-4">
                      <!-- Plastic Option -->
                      <label class="cursor-pointer relative">
                          <input type="radio" name="casetype" value="plastic" class="peer sr-only" checked>
                          <div class="rounded-xl border-2 border-gray-200 p-4 peer-checked:border-indigo-600 peer-checked:bg-indigo-50 hover:bg-gray-50 transition-all text-center">
                              <i class="fa-solid fa-shield-halved text-2xl text-gray-400 mb-2 peer-checked:text-indigo-600"></i>
                              <div class="font-semibold text-gray-800">Tough Plastic</div>
                              <div class="text-sm text-gray-500" id="price-plastic"></div>
                          </div>
                      </label>
                      <!-- Glass Option -->
                      <label class="cursor-pointer relative">
                          <input type="radio" name="casetype" value="glass" class="peer sr-only">
                          <div class="rounded-xl border-2 border-gray-200 p-4 peer-checked:border-indigo-600 peer-checked:bg-indigo-50 hover:bg-gray-50 transition-all text-center">
                              <i class="fa-solid fa-gem text-2xl text-gray-400 mb-2 peer-checked:text-indigo-600"></i>
                              <div class="font-semibold text-gray-800">Tempered Glass</div>
                              <div class="text-sm text-gray-500" id="price-glass"></div>
                          </div>
                      </label>
                  </div>
              </div>

              <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                  <h3 class="text-xl font-bold mb-4 text-gray-800">3. Customize Design</h3>
                  
                  <!-- Upload Button -->
                  <div class="mb-5">
                      <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-gray-300 rounded-xl cursor-pointer bg-gray-50 hover:bg-gray-100 hover:border-indigo-400 transition-all">
                          <div class="flex flex-col items-center justify-center pt-5 pb-6">
                              <i class="fa-solid fa-upload text-gray-400 text-2xl mb-2"></i>
                              <p class="mb-1 text-sm text-gray-600"><span class="font-semibold">Click to upload</span> or drag and drop</p>
                              <p class="text-xs text-gray-500">PNG, JPG (High Res Recommended)</p>
                          </div>
                          <input id="image-upload" type="file" class="hidden" accept="image/png, image/jpeg, image/jpg" />
                      </label>
                  </div>

                  <!-- Zoom Controls -->
                  <div id="zoom-controls" class="opacity-50 pointer-events-none transition-opacity">
                      <div class="flex justify-between text-sm text-gray-600 mb-2">
                          <span><i class="fa-solid fa-magnifying-glass-minus"></i> Zoom Out</span>
                          <span>Zoom In <i class="fa-solid fa-magnifying-glass-plus"></i></span>
                      </div>
                      <input type="range" id="zoom-slider" min="0.5" max="3" step="0.05" value="1" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-indigo-600">
                  </div>
              </div>

              <!-- Add to Cart / Export -->
              <div class="bg-gray-900 p-6 rounded-2xl text-white shadow-lg mt-auto">
                  <div class="flex justify-between items-end mb-4">
                      <div>
                          <p class="text-gray-400 text-sm">Total Price</p>
                          <p class="text-3xl font-bold" id="total-price">$0.00</p>
                      </div>
                  </div>
                  <button id="add-to-cart" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-4 px-6 rounded-xl transition-colors flex justify-center items-center gap-2 border-0">
                      <i class="fa-solid fa-cart-shopping"></i> Add to Cart
                  </button>
                  <p class="text-xs text-gray-400 text-center mt-3 text-balance">
                      Will attach the customized print file to the cart via Shopify API natively in this theme!
                  </p>
              </div>

          </div>
      </div>
  </div>
</div>

<!-- Success Modal -->
<div id="success-modal" class="fixed inset-0 bg-black/80 hidden flex items-center justify-center z-[99999] p-4 opacity-0 transition-opacity">
  <div class="bg-white rounded-2xl p-8 max-w-md w-full shadow-2xl transform scale-95 transition-transform" id="modal-content">
      <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <i class="fa-solid fa-check text-2xl text-green-600"></i>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-2">Design Ready!</h3>
          <p class="text-gray-500 mb-6">This flattened image will be added directly to your Shopify Cart automatically.</p>
          
          <div class="border rounded-xl overflow-hidden mb-6 bg-gray-50 flex justify-center p-4">
              <!-- Final Rendered Canvas will go here -->
              <canvas id="export-canvas" class="max-h-64 shadow-md rounded-3xl"></canvas>
          </div>

          <button id="close-modal" class="w-full bg-gray-900 hover:bg-gray-800 text-white font-bold py-3 px-4 rounded-xl transition-colors border-0">
              Close Preview
          </button>
      </div>
  </div>
</div>

<script>
  // --- LIQUID DATA INTEGRATION ---
  // If the product doesn't exist or isn't set, default to 15 and 25
  const basePricePlastic = {{ section.settings.base_product.variants[0].price | money_without_currency | default: "15.00" }};
  const basePriceGlass = {{ section.settings.base_product.variants[1].price | money_without_currency | default: "25.00" }};

  const prices = {
      plastic: parseFloat(basePricePlastic),
      glass: parseFloat(basePriceGlass)
  };

  // --- DATA STRUCTURE ---
  const deviceData = {
      "Apple": [
          { name: "iPhone 15 Pro Max", cameraHole: { x: 16, y: 20, w: 60, h: 65, rx: 14 } },
          { name: "iPhone 15", cameraHole: { x: 16, y: 20, w: 50, h: 50, rx: 12 } },
          { name: "iPhone 14 Pro", cameraHole: { x: 16, y: 20, w: 55, h: 60, rx: 12 } }
      ],
      "Samsung": [
          { name: "Galaxy S24 Ultra", cameraHole: { x: 15, y: 20, w: 30, h: 80, rx: 10 } },
          { name: "Galaxy S23", cameraHole: { x: 15, y: 20, w: 25, h: 60, rx: 8 } }
      ],
      "Google": [
          { name: "Pixel 8 Pro", cameraHole: { x: 0, y: 35, w: 240, h: 30, rx: 0 } }
      ]
  };

  // --- STATE ---
  let currentScale = 1;
  let translateX = 0;
  let translateY = 0;
  let isDragging = false;
  let startX, startY;
  let uploadedImgObj = null;

  // --- DOM ELEMENTS ---
  const brandSelect = document.getElementById('brand-select');
  const modelSelect = document.getElementById('model-select');
  const priceDisplay = document.getElementById('total-price');
  const caseTypeRadios = document.querySelectorAll('input[name="casetype"]');
  const phoneContainer = document.getElementById('phone-mockup');
  const glassGlare = document.getElementById('glass-glare');
  const cameraModule = document.getElementById('camera-module');
  
  const imageUpload = document.getElementById('image-upload');
  const designImage = document.getElementById('design-image');
  const placeholderText = document.getElementById('placeholder-text');
  const zoomSlider = document.getElementById('zoom-slider');
  const zoomControls = document.getElementById('zoom-controls');

  const pricePlasticDisplay = document.getElementById('price-plastic');
  const priceGlassDisplay = document.getElementById('price-glass');

  // Set the Liquid-injected prices in the UI labels
  pricePlasticDisplay.textContent = `+$${prices.plastic.toFixed(2)}`;
  priceGlassDisplay.textContent = `+$${prices.glass.toFixed(2)}`;

  // --- INITIALIZATION ---
  function init() {
      // Populate Brands
      Object.keys(deviceData).forEach(brand => {
          const opt = document.createElement('option');
          opt.value = brand;
          opt.textContent = brand;
          brandSelect.appendChild(opt);
      });

      // Listeners
      brandSelect.addEventListener('change', updateModels);
      modelSelect.addEventListener('change', updateCameraHole);
      caseTypeRadios.forEach(r => r.addEventListener('change', updateCaseType));
      imageUpload.addEventListener('change', handleImageUpload);
      zoomSlider.addEventListener('input', handleZoom);

      setupDraggable();
      updateModels();
      updateCaseType();
  }

  function updateModels() {
      const brand = brandSelect.value;
      const models = deviceData[brand];
      
      modelSelect.innerHTML = '';
      models.forEach((model, index) => {
          const opt = document.createElement('option');
          opt.value = index;
          opt.textContent = model.name;
          modelSelect.appendChild(opt);
      });
      updateCameraHole();
  }

  function updateCameraHole() {
      const brand = brandSelect.value;
      const modelIndex = modelSelect.value;
      const cam = deviceData[brand][modelIndex].cameraHole;
      
      cameraModule.innerHTML = `
          <rect x="${cam.x}" y="${cam.y}" width="${cam.w}" height="${cam.h}" rx="${cam.rx}" fill="#1f2937" stroke="#334155" stroke-width="2" />
          <rect x="${cam.x + 2}" y="${cam.y + 2}" width="${cam.w - 4}" height="${cam.h - 4}" rx="${cam.rx - 2}" fill="#0f172a" />
      `;
      if(cam.w > 40) {
           cameraModule.innerHTML += `<circle cx="${cam.x + 15}" cy="${cam.y + 15}" r="6" fill="#020617" stroke="#334155" stroke-width="1"/>`;
      }
  }

  function updateCaseType() {
      const type = document.querySelector('input[name="casetype"]:checked').value;
      priceDisplay.textContent = `Shopify Format Rate: $${prices[type].toFixed(2)}`;
      
      if(type === 'glass') {
          phoneContainer.classList.remove('plastic-case');
          phoneContainer.classList.add('glass-case');
          glassGlare.setAttribute('opacity', '1');
      } else {
          phoneContainer.classList.remove('glass-case');
          phoneContainer.classList.add('plastic-case');
          glassGlare.setAttribute('opacity', '0');
      }
  }

  function handleImageUpload(e) {
      const file = e.target.files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = function(event) {
          designImage.src = event.target.result;
          designImage.style.display = 'block';
          placeholderText.style.display = 'none';
          zoomControls.classList.remove('opacity-50', 'pointer-events-none');
          
          currentScale = 1;
          translateX = 0;
          translateY = 0;
          zoomSlider.value = 1;
          updateTransform();

          uploadedImgObj = new Image();
          uploadedImgObj.src = event.target.result;
      };
      reader.readAsDataURL(file);
  }

  function handleZoom(e) {
      currentScale = parseFloat(e.target.value);
      updateTransform();
  }

  function updateTransform() {
      designImage.style.transform = `translate(${translateX}px, ${translateY}px) scale(${currentScale})`;
  }

  function setupDraggable() {
      const startDrag = (e) => {
          if (designImage.style.display === 'none') return;
          isDragging = true;
          const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
          const clientY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
          startX = clientX - translateX;
          startY = clientY - translateY;
      };

      const doDrag = (e) => {
          if (!isDragging) return;
          e.preventDefault();
          const clientX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
          const clientY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
          translateX = clientX - startX;
          translateY = clientY - startY;
          updateTransform();
      };

      const endDrag = () => {
          isDragging = false;
      };

      designImage.addEventListener('mousedown', startDrag);
      window.addEventListener('mousemove', doDrag);
      window.addEventListener('mouseup', endDrag);

      designImage.addEventListener('touchstart', startDrag, { passive: false });
      window.addEventListener('touchmove', doDrag, { passive: false });
      window.addEventListener('touchend', endDrag);
  }

  const addToCartBtn = document.getElementById('add-to-cart');
  const modal = document.getElementById('success-modal');
  const closeModalBtn = document.getElementById('close-modal');
  const exportCanvas = document.getElementById('export-canvas');
  const ctx = exportCanvas.getContext('2d');

  addToCartBtn.addEventListener('click', () => {
      if(!uploadedImgObj) {
          alert("Please upload an image first!");
          return;
      }

      addToCartBtn.innerHTML = '<div class="loader w-5 h-5 rounded-full border-2 border-white"></div> Processing...';
      addToCartBtn.disabled = true;

      setTimeout(() => {
          generatePrintFile();
          
          modal.classList.remove('hidden');
          setTimeout(() => {
              modal.classList.remove('opacity-0');
              document.getElementById('modal-content').classList.remove('scale-95');
          }, 10);

          addToCartBtn.innerHTML = '<i class="fa-solid fa-cart-shopping"></i> Add to Cart';
          addToCartBtn.disabled = false;
      }, 800);
  });

  function generatePrintFile() {
      const width = 240;
      const height = 480;
      exportCanvas.width = width;
      exportCanvas.height = height;

      ctx.fillStyle = '#ffffff';
      ctx.beginPath();
      ctx.roundRect(0, 0, width, height, 36);
      ctx.fill();
      ctx.clip(); 

      const imgAspect = uploadedImgObj.width / uploadedImgObj.height;
      const contAspect = width / height;
      let drawW, drawH;

      if (imgAspect > contAspect) {
          drawH = height;
          drawW = uploadedImgObj.width * (height / uploadedImgObj.height);
      } else {
          drawW = width;
          drawH = uploadedImgObj.height * (width / uploadedImgObj.width);
      }

      const centerX = (width - drawW) / 2;
      const centerY = (height - drawH) / 2;

      ctx.translate(width / 2, height / 2);
      ctx.translate(translateX, translateY);
      ctx.scale(currentScale, currentScale);
      ctx.translate(-width / 2, -height / 2);
      
      ctx.drawImage(uploadedImgObj, centerX, centerY, drawW, drawH);
      ctx.setTransform(1, 0, 0, 1, 0, 0);

      const brand = brandSelect.value;
      const modelIndex = modelSelect.value;
      const cam = deviceData[brand][modelIndex].cameraHole;
      
      ctx.globalCompositeOperation = 'destination-out';
      ctx.beginPath();
      ctx.roundRect(cam.x, cam.y, cam.w, cam.h, cam.rx);
      ctx.fill();
      ctx.globalCompositeOperation = 'source-over';
      
      ctx.strokeStyle = '#e5e7eb';
      ctx.lineWidth = 2;
      ctx.stroke();
  }

  closeModalBtn.addEventListener('click', () => {
      modal.classList.add('opacity-0');
      document.getElementById('modal-content').classList.add('scale-95');
      setTimeout(() => {
          modal.classList.add('hidden');
      }, 300);
  });

  init();
</script>

{% schema %}
{
  "name": "Vanilla Case Customizer",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Customizer Title",
      "default": "CustomCases."
    },
    {
      "type": "product",
      "id": "base_product",
      "label": "Base Product Setup",
      "info": "Connects pricing dynamically to Shopify."
    }
  ],
  "presets": [
    {
      "name": "Vanilla Case Customizer",
      "category": "Custom"
    }
  ]
}
{% endschema %}